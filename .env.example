# Neon Postgres connection string.
# Get this from your Neon project dashboard -> Connection Details -> Connection string.
# Make sure it includes ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# OpenAI API key used by the AI research/news/briefing routes.
OPENAI_API_KEY="sk-proj-..."

# App password gating the dashboard and all API routes. Pick a long random
# value. REQUIRED in production — without it the server refuses API requests.
# (In local development, auth is skipped when this is unset.)
# Rotating it invalidates all existing sessions.
APP_PASSWORD="choose-a-long-random-password"
